# GugakPlace 환경 변수 예시. 복사해서 .env 로 쓰고 값을 채운다.
# .env 는 커밋하지 않는다 (.gitignore).

# ── 공유마당 자유이용 음원 수집 (prep, 1회성) ──
GONGU_API_KEY=""
# GONGU_API_URL=https://gongu.copyright.or.kr/gongu/wrt/wrtApi/search.json

# ── Hugging Face Inference (의미 임베딩, jhgan/ko-sroberta-multitask 768차원) ──
# 채우면 generate_data.py 가 768차원 문맥 임베딩을 생성, 비우면 키워드 폴백(34차원).
# 런타임 자유 텍스트(query_text) 임베딩에도 사용된다 (AGENTS.md §3).
# 발급: https://huggingface.co/settings/tokens (read 권한)
HF_API_KEY=""

# ── BGM 생성 보조 (선택, fal.ai) ──
FAL_API_KEY=""

# ── 프론트엔드 origin (CORS) ──
# FRONTEND_URL=http://localhost:5173
